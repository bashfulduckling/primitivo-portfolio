---
import { education, research, publications, talks, teaching, honours, community } from "../data/cv";

// Build a flat search index at build time
const searchIndex = [
  ...education.map((item) => ({
    section: "education",
    sectionLabel: "Education",
    title: item.degree,
    subtitle: [item.field, item.institution].filter(Boolean).join(" · "),
    body: item.thesis || "",
    year: String(item.year),
  })),
  ...research.map((item) => ({
    section: "research",
    sectionLabel: "Research",
    title: item.title,
    subtitle: item.role,
    body: item.description,
    year: String(item.year),
  })),
  ...publications.books.map((pub) => ({
    section: "publications",
    sectionLabel: "Publications",
    title: pub.title,
    subtitle: `${pub.author} · ${pub.publisher}`,
    body: "",
    year: String(pub.year),
  })),
  ...publications.editedBooks.map((pub) => ({
    section: "publications",
    sectionLabel: "Publications",
    title: pub.title,
    subtitle: `${pub.editors} · ${pub.publisher}`,
    body: "",
    year: String(pub.year),
  })),
  ...publications.peerReviewed.map((pub) => ({
    section: "publications",
    sectionLabel: "Publications",
    title: pub.title,
    subtitle: `${pub.author || pub.authors || ""} · ${pub.journal}`,
    body: "",
    year: String(pub.year),
  })),
  ...publications.chapters.map((pub) => ({
    section: "publications",
    sectionLabel: "Publications",
    title: pub.title,
    subtitle: `${pub.author || pub.authors || ""} · ${pub.book} (${pub.publisher})`,
    body: "",
    year: String(pub.year),
  })),
  ...publications.reports.map((pub) => ({
    section: "publications",
    sectionLabel: "Publications",
    title: pub.title,
    subtitle: `${pub.author || pub.authors || ""} · ${pub.publisher}`,
    body: "",
    year: String(pub.year),
  })),
  ...talks.map((item) => ({
    section: "presentations",
    sectionLabel: "Presentations",
    title: item.title,
    subtitle: item.event,
    body: `${item.location} · ${item.dates}`,
    year: String(item.year),
  })),
  ...teaching.map((item) => ({
    section: "teaching",
    sectionLabel: "Teaching",
    title: item.position,
    subtitle: item.institution,
    body: item.description,
    year: String(item.year),
  })),
  ...honours.map((honour) => ({
    section: "honours",
    sectionLabel: "Honours",
    title: honour,
    subtitle: "",
    body: "",
    year: "",
  })),
  ...community.map((item) => ({
    section: "community",
    sectionLabel: "Community",
    title: item.title,
    subtitle: "",
    body: item.description,
    year: String(item.year),
  })),
];

const searchDataJson = JSON.stringify(searchIndex);
---

<div id="search-container">
  <div id="search-bar">
    <span id="search-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </span>
    <input
      id="search-input"
      type="search"
      placeholder="Search across all sections…"
      autocomplete="off"
      aria-label="Search portfolio"
      aria-controls="search-results"
      aria-expanded="false"
    />
    <button id="search-clear" aria-label="Clear search" hidden>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <div id="search-results" role="listbox" aria-label="Search results" hidden></div>
</div>

<script define:vars={{ searchDataJson }}>
  const DATA = JSON.parse(searchDataJson);

  const container = document.getElementById("search-container");
  const input = document.getElementById("search-input");
  const clearBtn = document.getElementById("search-clear");
  const results = document.getElementById("search-results");

  let activeIndex = -1;

  function highlight(text, query) {
    if (!query) return escapeHtml(text);
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    const re = new RegExp(`(${escaped})`, "gi");
    const parts = text.split(re);
    return parts.map((part, i) => {
      if (i % 2 === 1) {
        return `<mark class="search-highlight">${escapeHtml(part)}</mark>`;
      }
      return escapeHtml(part);
    }).join("");
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function doSearch(query) {
    query = query.trim();
    clearBtn.hidden = query.length === 0;

    if (query.length < 2) {
      closeResults();
      return;
    }

    const q = query.toLowerCase();
    const matches = DATA.filter((item) => {
      return (
        item.title.toLowerCase().includes(q) ||
        item.subtitle.toLowerCase().includes(q) ||
        item.body.toLowerCase().includes(q) ||
        item.year.includes(q)
      );
    });

    activeIndex = -1;

    if (matches.length === 0) {
      results.innerHTML = `<div class="search-no-results">No results for "<strong>${escapeHtml(query)}</strong>"</div>`;
    } else {
      const countLabel = `<div class="search-count">${matches.length} result${matches.length !== 1 ? "s" : ""} found</div>`;
      const items = matches
        .map(
          (item, i) => `
        <div class="search-result-item" role="option" data-index="${i}" data-section="${item.section}" tabindex="-1">
          <span class="search-result-section">${escapeHtml(item.sectionLabel)}</span>
          <span class="search-result-title">${highlight(item.title, query)}</span>
          ${item.subtitle ? `<span class="search-result-sub">${highlight(item.subtitle, query)}</span>` : ""}
          ${item.body ? `<span class="search-result-body">${highlight(item.body, query)}</span>` : ""}
        </div>`
        )
        .join("");
      results.innerHTML = countLabel + items;

      results.querySelectorAll(".search-result-item").forEach((el) => {
        el.addEventListener("click", () => {
          const section = el.dataset.section;
          navigateTo(section);
        });
        el.addEventListener("keydown", (e) => {
          if (e.key === "Enter") navigateTo(el.dataset.section);
        });
      });
    }

    results.hidden = false;
    input.setAttribute("aria-expanded", "true");
  }

  function navigateTo(sectionId) {
    const target = document.getElementById(sectionId);
    if (target) {
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }
    closeResults();
    input.value = "";
    clearBtn.hidden = true;
  }

  function closeResults() {
    results.hidden = true;
    results.innerHTML = "";
    input.setAttribute("aria-expanded", "false");
    activeIndex = -1;
  }

  function moveActive(dir) {
    const items = results.querySelectorAll(".search-result-item");
    if (!items.length) return;
    if (activeIndex === -1) {
      activeIndex = dir > 0 ? 0 : items.length - 1;
    } else {
      activeIndex = (activeIndex + dir + items.length) % items.length;
    }
    items.forEach((el, i) => {
      el.classList.toggle("search-result-active", i === activeIndex);
    });
    items[activeIndex]?.focus();
  }

  input.addEventListener("input", (e) => doSearch(e.target.value));

  input.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeResults();
      input.value = "";
      clearBtn.hidden = true;
    } else if (e.key === "ArrowDown") {
      e.preventDefault();
      moveActive(1);
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      moveActive(-1);
    } else if (e.key === "Enter") {
      const items = results.querySelectorAll(".search-result-item");
      if (activeIndex >= 0 && items[activeIndex]) {
        navigateTo(items[activeIndex].dataset.section);
      }
    }
  });

  clearBtn.addEventListener("click", () => {
    input.value = "";
    clearBtn.hidden = true;
    closeResults();
    input.focus();
  });

  document.addEventListener("click", (e) => {
    if (!container.contains(e.target)) {
      closeResults();
    }
  });
</script>

<style>
  #search-container {
    position: relative;
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
  }

  #search-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1.5px solid var(--border);
    border-radius: 28px;
    padding: 10px 16px;
    box-shadow: 0 2px 12px rgba(74, 144, 164, 0.08);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  #search-bar:focus-within {
    border-color: var(--accent-primary);
    box-shadow: 0 4px 20px rgba(74, 144, 164, 0.15);
  }

  #search-icon {
    color: var(--text-muted);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  #search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 0.95rem;
    color: var(--text-primary);
    font-family: inherit;
    min-width: 0;
  }

  #search-input::placeholder {
    color: var(--text-muted);
  }

  /* Hide the native clear button from type="search" */
  #search-input::-webkit-search-cancel-button {
    display: none;
  }

  #search-clear {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    padding: 2px;
    border-radius: 50%;
    transition: color 0.2s, background 0.2s;
    flex-shrink: 0;
  }

  #search-clear:hover {
    color: var(--accent-primary);
    background: rgba(74, 144, 164, 0.08);
  }

  #search-results {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: #fff;
    border: 1.5px solid var(--border);
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(74, 144, 164, 0.14);
    max-height: 420px;
    overflow-y: auto;
    z-index: 2000;
    padding: 8px 0;
  }

  .search-count {
    font-size: 0.8rem;
    color: var(--text-muted);
    padding: 6px 16px 10px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4px;
  }

  .search-no-results {
    padding: 20px 16px;
    color: var(--text-muted);
    font-size: 0.9rem;
    text-align: center;
  }

  .search-result-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 16px;
    cursor: pointer;
    border-radius: 8px;
    margin: 2px 6px;
    transition: background 0.15s;
    outline: none;
  }

  .search-result-item:hover,
  .search-result-item.search-result-active {
    background: rgba(74, 144, 164, 0.08);
  }

  .search-result-section {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--accent-primary);
  }

  .search-result-title {
    font-size: 0.93rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .search-result-sub {
    font-size: 0.83rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .search-result-body {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.search-highlight) {
    background: rgba(74, 144, 164, 0.18);
    color: var(--accent-dark);
    border-radius: 2px;
    font-weight: 700;
    padding: 0 1px;
  }

  @media (max-width: 768px) {
    #search-container {
      max-width: 100%;
    }

    #search-results {
      max-height: 320px;
    }
  }
</style>
