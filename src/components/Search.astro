---
import { education, research, publications, talks, teaching, honours, community } from "../data/cv";

const searchIndex = [
  ...education.map((item) => ({
    section: "education",
    sectionLabel: "Education",
    title: item.degree,
    subtitle: [item.field, item.institution].filter(Boolean).join(" · "),
    body: item.thesis || "",
    year: String(item.year),
  })),
  ...research.map((item) => ({
    section: "research",
    sectionLabel: "Research",
    title: item.title,
    subtitle: item.role,
    body: item.description,
    year: String(item.year),
  })),
  ...publications.books.map((pub) => ({
    section: "publications",
    sectionLabel: "Publications",
    title: pub.title,
    subtitle: `${pub.author} · ${pub.publisher}`,
    body: "",
    year: String(pub.year),
  })),
  ...publications.editedBooks.map((pub) => ({
    section: "publications",
    sectionLabel: "Publications",
    title: pub.title,
    subtitle: `${pub.editors} · ${pub.publisher}`,
    body: "",
    year: String(pub.year),
  })),
  ...publications.peerReviewed.map((pub) => ({
    section: "publications",
    sectionLabel: "Publications",
    title: pub.title,
    subtitle: `${pub.author || pub.authors || ""} · ${pub.journal}`,
    body: "",
    year: String(pub.year),
  })),
  ...publications.chapters.map((pub) => ({
    section: "publications",
    sectionLabel: "Publications",
    title: pub.title,
    subtitle: `${pub.author || pub.authors || ""} · ${pub.book} (${pub.publisher})`,
    body: "",
    year: String(pub.year),
  })),
  ...publications.reports.map((pub) => ({
    section: "publications",
    sectionLabel: "Publications",
    title: pub.title,
    subtitle: `${pub.author || pub.authors || ""} · ${pub.publisher}`,
    body: "",
    year: String(pub.year),
  })),
  ...talks.map((item) => ({
    section: "presentations",
    sectionLabel: "Presentations",
    title: item.title,
    subtitle: item.event,
    body: `${item.location} · ${item.dates}`,
    year: String(item.year),
  })),
  ...teaching.map((item) => ({
    section: "teaching",
    sectionLabel: "Teaching",
    title: item.position,
    subtitle: item.institution,
    body: item.description,
    year: String(item.year),
  })),
  ...honours.map((honour) => ({
    section: "honours",
    sectionLabel: "Honours",
    title: honour,
    subtitle: "",
    body: "",
    year: "",
  })),
  ...community.map((item) => ({
    section: "community",
    sectionLabel: "Community",
    title: item.title,
    subtitle: "",
    body: item.description,
    year: String(item.year),
  })),
];

const searchDataJson = JSON.stringify(searchIndex);
---

<div id="search-wrapper" class="search-wrapper">
  <button id="search-btn" class="search-btn" aria-label="Search">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
  </button>

  <div id="search-dropdown" class="search-dropdown" style="display: none;">
    <input
      id="search-input"
      type="search"
      placeholder="Search..."
      autocomplete="off"
      aria-label="Search portfolio"
    />
    <div id="search-results" class="search-results"></div>
  </div>
</div>

<script define:vars={{ searchDataJson }}>
  const DATA = JSON.parse(searchDataJson);
  
  const searchBtn = document.getElementById("search-btn");
  const searchDropdown = document.getElementById("search-dropdown");
  const searchInput = document.getElementById("search-input");
  const searchResults = document.getElementById("search-results");
  const searchWrapper = document.getElementById("search-wrapper");

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function highlight(text, query) {
    if (!query) return escapeHtml(text);
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    const re = new RegExp(`(${escaped})`, "gi");
    const parts = text.split(re);
    return parts.map((part, i) => {
      if (i % 2 === 1) {
        return `<mark>${escapeHtml(part)}</mark>`;
      }
      return escapeHtml(part);
    }).join("");
  }

  function navigateTo(sectionId) {
    const target = document.getElementById(sectionId);
    if (target) {
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }
    closeSearch();
  }

  function closeSearch() {
    searchDropdown.style.display = "none";
    searchResults.innerHTML = "";
    searchInput.value = "";
  }

  function openSearch() {
    searchDropdown.style.display = "flex";
    searchInput.focus();
  }

  function doSearch(query) {
    query = query.trim();

    if (query.length < 2) {
      searchResults.innerHTML = "";
      return;
    }

    const q = query.toLowerCase();
    const matches = DATA.filter((item) => {
      return (
        item.title.toLowerCase().includes(q) ||
        item.subtitle.toLowerCase().includes(q) ||
        item.body.toLowerCase().includes(q)
      );
    }).slice(0, 8);

    if (matches.length === 0) {
      searchResults.innerHTML = `<div class="no-results">No results found</div>`;
      return;
    }

    const items = matches
      .map(
        (item) => `
      <button class="result-item" data-section="${escapeHtml(item.section)}">
        <div class="result-section">${escapeHtml(item.sectionLabel)}</div>
        <div class="result-title">${highlight(item.title, query)}</div>
        ${item.subtitle ? `<div class="result-sub">${highlight(item.subtitle, query)}</div>` : ""}
      </button>`
      )
      .join("");

    searchResults.innerHTML = items;

    document.querySelectorAll(".result-item").forEach((btn) => {
      btn.addEventListener("click", function() {
        const section = this.getAttribute("data-section");
        navigateTo(section);
      });
    });
  }

  searchBtn.addEventListener("click", openSearch);
  searchInput.addEventListener("input", (e) => doSearch(e.target.value));
  
  document.addEventListener("click", (e) => {
    if (!searchWrapper.contains(e.target)) {
      closeSearch();
    }
  });

  searchInput.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeSearch();
    }
  });
</script>

<style>
  .search-wrapper {
    position: relative;
  }

  .search-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    border-radius: 6px;
    transition: background 0.2s;
  }

  .search-btn:hover {
    background: rgba(74, 144, 164, 0.08);
  }

  .search-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 12px;
    width: 360px;
    max-height: 500px;
    margin-top: 8px;
    flex-direction: column;
    z-index: 1000;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    overflow: hidden;
  }

  #search-input {
    padding: 14px 16px;
    border: none;
    border-bottom: 1px solid var(--border);
    background: transparent;
    color: var(--text-primary);
    font-size: 14px;
    outline: none;
    font-family: inherit;
    flex-shrink: 0;
  }

  #search-input::placeholder {
    color: var(--text-secondary);
  }

  .search-results {
    overflow-y: auto;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .result-item {
    padding: 12px 16px;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
    display: flex;
    flex-direction: column;
    gap: 3px;
    font-family: inherit;
    border-bottom: 1px solid var(--border);
  }

  .result-item:last-child {
    border-bottom: none;
  }

  .result-item:hover {
    background: transparent;
  }

  .result-section {
    font-size: 10px;
    color: var(--text-secondary);
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .result-title {
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 500;
    line-height: 1.3;
  }

  .result-sub {
    font-size: 11px;
    color: var(--text-secondary);
    line-height: 1.3;
  }

  mark {
    background: rgba(74, 144, 164, 0.25);
    color: inherit;
    font-weight: 600;
    border-radius: 1px;
    padding: 0 1px;
  }

  .no-results {
    padding: 24px 16px;
    text-align: center;
    color: var(--text-secondary);
    font-size: 13px;
  }

  /* Scrollbar styling */
  .search-results::-webkit-scrollbar {
    width: 6px;
  }

  .search-results::-webkit-scrollbar-track {
    background: transparent;
  }

  .search-results::-webkit-scrollbar-thumb {
    background: var(--text-secondary);
    border-radius: 3px;
  }

  .search-results::-webkit-scrollbar-thumb:hover {
    background: var(--text-primary);
  }
</style>